// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum Role {
  HEAD
  ADMIN
  STAFF
  CLIENT
}

enum UserSource {
  LOCAL
  GOOGLE
  MAGIC_LINK
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  name          String?
  firstName     String?
  lastName      String?
  password      String?
  role          Role       @default(CLIENT)
  source        UserSource @default(LOCAL)
  emailVerified DateTime?
  image         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  accounts Account[]
  sessions Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Faq {
  id        String   @id @default(cuid())
  question  String   @unique
  answer    String
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("faqs")
}

model PolicyDoc {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("policy_docs")
}

model MediaAsset {
  id         String   @id @default(cuid())
  key        String   @unique
  url        String
  filename   String
  mimeType   String?
  size       Int?
  bucket     String?
  uploadedBy String?
  createdAt  DateTime @default(now())

  @@map("media_assets")
}

model Enquiry {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("enquiries")
}